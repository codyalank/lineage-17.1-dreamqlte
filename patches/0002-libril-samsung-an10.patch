From 0f957ce5b9c66be294ac457550e43e91b8891d29 Mon Sep 17 00:00:00 2001
From: S8 Builder <build@s8.local>
Date: Mon, 9 Mar 2026 10:07:15 +0000
Subject: [PATCH] libril: add Samsung AN10 registration state compat

- currentSignalStrengthInd: use < sizeof instead of != sizeof
- getVoiceRegistrationStateResponse: handle NULL response as NOT_REG
- getDataRegistrationStateResponse: handle NULL response as NOT_REG
- Voice/data reg struct size: use < sizeof to accept extended structs
- Add char** string format detection for Samsung version=15 quirk

Change-Id: I0656372d04e2a65ae992a4fa1d7f3b6c3f06bcf0
---
 libril/ril_service.cpp | 113 +++++++++++++++++++++++++++--------------
 1 file changed, 75 insertions(+), 38 deletions(-)

diff --git a/libril/ril_service.cpp b/libril/ril_service.cpp
index 6f8c79e..bb37177 100755
--- a/libril/ril_service.cpp
+++ b/libril/ril_service.cpp
@@ -3492,12 +3492,14 @@ int radio::getSignalStrengthResponse(int slotId,
         RadioResponseInfo responseInfo = {};
         populateResponseInfo(responseInfo, serial, responseType, e);
         SignalStrength signalStrength = {};
-        if (response == NULL || (responseLen != sizeof(RIL_SignalStrength_v10)
-                && responseLen != sizeof(RIL_SignalStrength_v8))) {
+        if (response == NULL || responseLen < sizeof(RIL_SignalStrength_v8)) {
             RLOGE("getSignalStrengthResponse: Invalid response");
             if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
         } else {
-            convertRilSignalStrengthToHal(response, responseLen, signalStrength);
+            // Accept v8, v10, or Samsung-extended struct sizes
+            size_t parseLen = responseLen;
+            if (parseLen > sizeof(RIL_SignalStrength_v10)) parseLen = sizeof(RIL_SignalStrength_v10);
+            convertRilSignalStrengthToHal(response, parseLen, signalStrength);
         }
 
         Return<void> retStatus = radioService[slotId]->mRadioResponse->getSignalStrengthResponse(
@@ -3865,11 +3867,15 @@ int radio::getVoiceRegistrationStateResponse(int slotId,
 
         VoiceRegStateResult voiceRegResponse = {};
         int numStrings = responseLen / sizeof(char *);
-        if (response == NULL) {
-               RLOGE("getVoiceRegistrationStateResponse Invalid response: NULL");
-               if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
+        if (response == NULL && s_vendorFunctions->version > 14) {
+               // Samsung AN10: NULL response = NOT_REGISTERED (modem searching), not an error
+               RLOGE("getVoiceRegistrationStateResponse: NULL response (Samsung AN10 NOT_REG)");
+               voiceRegResponse.regState = (RegState)2; // NOT_REG_OR_SEARCHING
+        } else if (response == NULL) {
+               // Samsung Pie (version<=14): NULL response means NOT_REGISTERED, not an error
+               RLOGE("getVoiceRegistrationStateResponse: NULL response (Samsung Pie NOT_REG)");
         } else if (s_vendorFunctions->version <= 14) {
-            if (numStrings != 15) {
+            if (numStrings < 15) {
                 RLOGE("getVoiceRegistrationStateResponse Invalid response: NULL");
                 if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
             } else {
@@ -3885,22 +3891,37 @@ int radio::getVoiceRegistrationStateResponse(int slotId,
                         numStrings, resp);
             }
         } else {
-            RIL_VoiceRegistrationStateResponse *voiceRegState =
-                    (RIL_VoiceRegistrationStateResponse *)response;
-
-            if (responseLen != sizeof(RIL_VoiceRegistrationStateResponse)) {
-                RLOGE("getVoiceRegistrationStateResponse Invalid response: NULL");
-                if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
+            // Samsung AN10 (version=15) sends char** strings despite version>14.
+            // Detect by size: struct=56 bytes (numStrings=7), char**=15+ strings.
+            if (numStrings >= 15 && numStrings <= 25) {
+                char **resp = (char **) response;
+                voiceRegResponse.regState = (RegState) ATOI_NULL_HANDLED_DEF(resp[0], 4);
+                voiceRegResponse.rat = ATOI_NULL_HANDLED(resp[3]);
+                voiceRegResponse.cssSupported = ATOI_NULL_HANDLED_DEF(resp[7], 0);
+                voiceRegResponse.roamingIndicator = ATOI_NULL_HANDLED(resp[10]);
+                voiceRegResponse.systemIsInPrl = ATOI_NULL_HANDLED_DEF(resp[11], 0);
+                voiceRegResponse.defaultRoamingIndicator = ATOI_NULL_HANDLED_DEF(resp[12], 0);
+                voiceRegResponse.reasonForDenial = ATOI_NULL_HANDLED_DEF(resp[13], 0);
+                fillCellIdentityFromVoiceRegStateResponseString(voiceRegResponse.cellIdentity,
+                        numStrings, resp);
             } else {
-                voiceRegResponse.regState = (RegState) voiceRegState->regState;
-                voiceRegResponse.rat = voiceRegState->rat;;
-                voiceRegResponse.cssSupported = voiceRegState->cssSupported;
-                voiceRegResponse.roamingIndicator = voiceRegState->roamingIndicator;
-                voiceRegResponse.systemIsInPrl = voiceRegState->systemIsInPrl;
-                voiceRegResponse.defaultRoamingIndicator = voiceRegState->defaultRoamingIndicator;
-                voiceRegResponse.reasonForDenial = voiceRegState->reasonForDenial;
-                fillCellIdentityResponse(voiceRegResponse.cellIdentity,
-                        voiceRegState->cellIdentity);
+                RIL_VoiceRegistrationStateResponse *voiceRegState =
+                        (RIL_VoiceRegistrationStateResponse *)response;
+
+                if (responseLen < sizeof(RIL_VoiceRegistrationStateResponse)) {
+                    RLOGE("getVoiceRegistrationStateResponse Invalid response: NULL");
+                    if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
+                } else {
+                    voiceRegResponse.regState = (RegState) voiceRegState->regState;
+                    voiceRegResponse.rat = voiceRegState->rat;;
+                    voiceRegResponse.cssSupported = voiceRegState->cssSupported;
+                    voiceRegResponse.roamingIndicator = voiceRegState->roamingIndicator;
+                    voiceRegResponse.systemIsInPrl = voiceRegState->systemIsInPrl;
+                    voiceRegResponse.defaultRoamingIndicator = voiceRegState->defaultRoamingIndicator;
+                    voiceRegResponse.reasonForDenial = voiceRegState->reasonForDenial;
+                    fillCellIdentityResponse(voiceRegResponse.cellIdentity,
+                            voiceRegState->cellIdentity);
+                }
             }
         }
 
@@ -3927,9 +3948,13 @@ int radio::getDataRegistrationStateResponse(int slotId,
         RadioResponseInfo responseInfo = {};
         populateResponseInfo(responseInfo, serial, responseType, e);
         DataRegStateResult dataRegResponse = {};
-        if (response == NULL) {
-            RLOGE("getDataRegistrationStateResponse Invalid response: NULL");
-            if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
+        if (response == NULL && s_vendorFunctions->version > 14) {
+            // Samsung AN10: NULL response = NOT_REGISTERED (modem searching), not an error
+            RLOGE("getDataRegistrationStateResponse: NULL response (Samsung AN10 NOT_REG)");
+            dataRegResponse.regState = (RegState)2; // NOT_REG_OR_SEARCHING
+        } else if (response == NULL) {
+            // Samsung Pie (version<=14): NULL response means NOT_REGISTERED, not an error
+            RLOGE("getDataRegistrationStateResponse: NULL response (Samsung Pie NOT_REG)");
         } else if (s_vendorFunctions->version <= 14) {
             int numStrings = responseLen / sizeof(char *);
             if ((numStrings != 6) && (numStrings != 11) && (numStrings != 13)) {
@@ -3945,18 +3970,31 @@ int radio::getDataRegistrationStateResponse(int slotId,
                         numStrings, resp);
             }
         } else {
-            RIL_DataRegistrationStateResponse *dataRegState =
-                    (RIL_DataRegistrationStateResponse *)response;
-
-            if (responseLen != sizeof(RIL_DataRegistrationStateResponse)) {
-                RLOGE("getDataRegistrationStateResponse Invalid response: NULL");
-                if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
+            // Samsung AN10 (version=15) sends char** strings despite version>14.
+            // Detect by size: struct=44 bytes (numStrings=5), char**=6/11/13 strings.
+            int dataNumStrings = responseLen / sizeof(char *);
+            if ((dataNumStrings == 6) || (dataNumStrings == 11) || (dataNumStrings == 13)) {
+                char **resp = (char **) response;
+                dataRegResponse.regState = (RegState) ATOI_NULL_HANDLED_DEF(resp[0], 4);
+                dataRegResponse.rat = ATOI_NULL_HANDLED_DEF(resp[3], 0);
+                dataRegResponse.reasonDataDenied = ATOI_NULL_HANDLED(resp[4]);
+                dataRegResponse.maxDataCalls = ATOI_NULL_HANDLED_DEF(resp[5], 1);
+                fillCellIdentityFromDataRegStateResponseString(dataRegResponse.cellIdentity,
+                        dataNumStrings, resp);
             } else {
-                dataRegResponse.regState = (RegState) dataRegState->regState;
-                dataRegResponse.rat = dataRegState->rat;;
-                dataRegResponse.reasonDataDenied = dataRegState->reasonDataDenied;
-                dataRegResponse.maxDataCalls = dataRegState->maxDataCalls;
-                fillCellIdentityResponse(dataRegResponse.cellIdentity, dataRegState->cellIdentity);
+                RIL_DataRegistrationStateResponse *dataRegState =
+                        (RIL_DataRegistrationStateResponse *)response;
+
+                if (responseLen < sizeof(RIL_DataRegistrationStateResponse)) {
+                    RLOGE("getDataRegistrationStateResponse Invalid response: NULL");
+                    if (e == RIL_E_SUCCESS) responseInfo.error = RadioError::INVALID_RESPONSE;
+                } else {
+                    dataRegResponse.regState = (RegState) dataRegState->regState;
+                    dataRegResponse.rat = dataRegState->rat;;
+                    dataRegResponse.reasonDataDenied = dataRegState->reasonDataDenied;
+                    dataRegResponse.maxDataCalls = dataRegState->maxDataCalls;
+                    fillCellIdentityResponse(dataRegResponse.cellIdentity, dataRegState->cellIdentity);
+                }
             }
         }
 
@@ -7202,8 +7240,7 @@ int radio::currentSignalStrengthInd(int slotId,
                                     int indicationType, int token, RIL_Errno e,
                                     void *response, size_t responseLen) {
     if (radioService[slotId] != NULL && radioService[slotId]->mRadioIndication != NULL) {
-        if (response == NULL || (responseLen != sizeof(RIL_SignalStrength_v10)
-                && responseLen != sizeof(RIL_SignalStrength_v8))) {
+        if (response == NULL || responseLen < sizeof(RIL_SignalStrength_v8)) {
             RLOGE("currentSignalStrengthInd: invalid response");
             return 0;
         }
-- 
2.34.1

